    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[0].line
      value: "Ch\xFAc m\u1EEBng c\xE1c b\u1EA1n \u0111\xE3 ho\xE0n th\xE0nh nhi\u1EC7m
        v\u1EE5 m\u1ED9t c\xE1ch xu\u1EA5t s\u1EAFc!"
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[1].line
      value: "C\u1EA3m \u01A1n v\xEC \u0111\xE3 b\u1EC1n b\u1EC9 v\u01B0\u1EE3t qua
        m\u1ECDi kh\xF3 kh\u0103n \u0111\u1EC3 v\u1EADn chuy\u1EC3n h\xE0ng h\xF3a
        an to\xE0n \u0111\u1EBFn \u0111\xEDch.\n"
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[2].line
      value: "Nh\u1EEFng chuy\u1EBFn xe c\u1EE7a b\u1EA1n kh\xF4ng ch\u1EC9 ch\u1EDF
        theo h\xE0ng h\xF3a, m\xE0 c\xF2n mang theo s\u1EF1 gi\xFAp \u0111\u1EE1
        v\xE0 hy v\u1ECDng \u0111\u1EBFn v\u1EDBi anh em \u1EDF \u0111\xE2y"
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[3].line
      value: "T\u1EA1m th\u1EDDi c\xE1c b\u1EA1n h\xE3y ngh\u0129 ng\u01A1i \u0111\u1EC3
        s\u1EB5n s\xE0ng cho nh\u1EEFng nhi\u1EC7m v\u1EE5 ti\u1EBFp theo  nh\xE9!! "
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[0].character.name
