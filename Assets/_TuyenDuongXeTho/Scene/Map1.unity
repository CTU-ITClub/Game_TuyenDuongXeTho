      objectReference: {fileID: 1874919253}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[0].line
      value: "Ch\xE0o \u0111\u1ED3ng ch\xED, t\xF4i l\xE0 Hu\xE2n, anh trai sinh
        \u0111\xF4i c\u1EE7a Ph\xFA b\xEAn \u0111\u1EA1i \u0111\u1ED9i trinh s\xE1t
        \u0111\xE2y. Ch\u1EAFc nh\xECn m\u1EB7t t\xF4i c\u1EADu th\u1EA5y quen l\u1EAFm
        \u0111\xFAng kh\xF4ng, hai anh em gi\u1ED1ng nhau nh\u01B0 hai gi\u1ECDt
        n\u01B0\u1EDBc m\xE0.\r\n"
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[1].line
      value: "Nh\xECn d\u1EA3i \u0111\u1EA5t tr\u1ED1ng t\u01B0\u1EDFng b\xECnh y\xEAn
        tr\u01B0\u1EDBc m\u1EB7t kia \u0111i, \u0111\u1ECBch n\xF3 g\xE0i k\xEDn
        m\xECn b\xEAn d\u01B0\u1EDBi \u0111\u1EA5y."
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[2].line
      value: "Tuy nhi\xEAn \u0111\xE3 \u0111\u1EBFn \u0111\u01B0\u1EE3c \u0111\xE2y
        t\xF4i tin c\xE1c c\u1EADu qua \u0111\u01B0\u1EE3c d\u1EC5 d\xE0ng m\xE0
        ch\u1EC9 c\u1EA7n c\u1EA9n th\u1EADn th\u1EADt k\u0129 l\xE0 \u0111\u01B0\u1EE3c."
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
