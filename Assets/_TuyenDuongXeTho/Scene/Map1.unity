      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 7308711544950241990, guid: 1ef72282cc9fb854e9c15cce1bc34059, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[0].line
      value: "Ch\xE0o \u0111\u1ED3ng ch\xED, t\xF4i l\xE0 \xDAt, d\xE2n c\xF4ng tuy\u1EBFn
        c\u1EE7a Ph\xF9 Y\xEAn."
      objectReference: {fileID: 0}
    - target: {fileID: 7308711544950241990, guid: 1ef72282cc9fb854e9c15cce1bc34059, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[1].line
      value: "M\u1EA5y h\xF4m nay t\xF4i \u0111\u01B0\u1EE3c ph\xE2n c\xF4ng \u0111i
        tr\u01B0\u1EDBc m\u1EDF \u0111\u01B0\u1EDDng cho c\xE1c c\u1EB7p th\u1ED3."
      objectReference: {fileID: 0}
    - target: {fileID: 7308711544950241990, guid: 1ef72282cc9fb854e9c15cce1bc34059, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[2].line
      value: "\u0110\u01B0\u1EDDng v\xE0o \u0110\u01B0\u1EDDng s\u1ED1 13 c\xE1ch
        \u0111\xE2y kh\xF4ng c\xF2n xa n\u1EEFa \u0111\xE2u, nh\u01B0ng \u0111o\u1EA1n
        ph\xEDa tr\u01B0\u1EDBc \u0111ang b\u1ECB bom c\u1EE7a \u0111\u1ECBch \u0111\xE1nh
        ph\xE1 l\xE0m \u0111o\u1EA1n \u0111\u01B0\u1EDDng \u0111i b\u1ECB s\u1EA1t
        l\u1EDF."
      objectReference: {fileID: 0}
    - target: {fileID: 7308711544950241990, guid: 1ef72282cc9fb854e9c15cce1bc34059, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[3].line
      value: "C\xE1c c\u1EADu c\u1EA7n ph\u1EA3i ph\u1ED1i h\u1EE3p v\u1EDBi nhau
        \u0111\u1EC3 tr\xE1nh \u0111\u1EC3 b\xE1nh xe k\u1EB9t tr\xEAn \u0111\u01B0\u1EDDng
        nh\xE9 v\xE0 ch\xFA \xFD bom c\u1EE7a k\u1EBB \u0111\u1ECBch n\u1EEFa."
      objectReference: {fileID: 0}
    - target: {fileID: 7308711544950241990, guid: 1ef72282cc9fb854e9c15cce1bc34059, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[4].line
      value: "\xC0 v\xE0 nh\u1EDB tr\xF2 chuy\u1EC7n v\u1EDBi c\xE1c \u0111\u1ED3ng
        \u0111\u1ED9i ta tr\xEAn \u0111\u01B0\u1EDDng \u0111\u1EC3 h\u1ECD h\u01B0\u1EDBng
        d\u1EABn c\xE1c c\u1EADu nghe."
      objectReference: {fileID: 0}
