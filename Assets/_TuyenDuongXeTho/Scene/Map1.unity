    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[0].line
      value: "Ngh\u1EC9 ch\xE2n \u0111\xE3 n\xE0o hai \u0111\u1ED3ng ch\xED, t\xF4i
        l\xE0 Ph\xFA thu\u1ED9c \u0111\u1EA1i \u0111\u1ED9i trinh s\xE1t."
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[1].line
      value: "C\xE1c c\u1EADu \u0111\xE3 qua \u0111\u01B0\u1EE3c \u0111o\u1EA1n s\u1EA1t
        l\u1EDF r\u1ED3i, r\u1EA5t t\u1ED1t! Nh\u01B0ng ch\u1EB7ng \u0111\u01B0\u1EDDng
        tr\u1ED1ng ph\xEDa tr\u01B0\u1EDBc m\u1EDBi th\u1EF1c s\u1EF1 kh\u1ED1c li\u1EC7t."
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[2].line
      value: "H\xE3y ch\xFA \xFD k\u1EF9, tr\u01B0\u1EDBc khi bom ch\u1EA1m \u0111\u1EA5t
        s\u1EBD c\xF3 m\u1ED9t v\xF9ng s\xE1ng m\xE0u \u0111\u1ECF hi\u1EC7n l\xEAn,
        b\u1EB1ng m\u1ECDi gi\xE1 c\xE1c c\u1EADu ph\u1EA3i nhanh ch\xE2n n\xE9 ra
        kh\u1ECFi v\xF9ng \u0111\xF3 \u0111\u1EC3 gi\u1EEF m\u1EA1ng.  "
      objectReference: {fileID: 0}
    - target: {fileID: 4959014758460235975, guid: ac627d59ba0a0484b9d758a32e97d005, type: 3}
      propertyPath: dialogue.dialogueLines.Array.data[3].line
      value: "B\u1EA3o to\xE0n \u0111\u01B0\u1EE3c l\u1EF1c l\u01B0\u1EE3ng th\xEC
        m\u1EDBi \u0111\u01B0a \u0111\u01B0\u1EE3c g\u1EA1o ra ti\u1EC1n tuy\u1EBFn.
        Ph\u1ED1i h\u1EE3p cho \u0103n \xFD nh\xE9, ti\u1EBFn l\xEAn!"
      objectReference: {fileID: 0}
